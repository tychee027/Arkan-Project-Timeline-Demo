rules_version = '2';

// Example Firestore security rules for the Arkan Project Timeline app.
//
// This app has no built-in authentication layer, so by default these rules
// simply lock the database down (deny all). Uncomment ONE of the options
// below depending on how you want to control access, or write your own.
//
// Paste this into: Firebase console → Firestore Database → Rules.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Option A (default): deny everyone until you choose a policy below ──
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Option B: allow anyone with your Firebase config to read/write ──
    // Only suitable for a private demo/internal tool where the config
    // itself isn't shared publicly. Comment out Option A above and
    // uncomment this block instead:
    //
    // match /projects/{id} {
    //   allow read, write: if true;
    // }
    // match /tasks/{id} {
    //   allow read, write: if true;
    // }
    // match /meta/{id} {
    //   allow read, write: if true;
    // }

    // ── Option C: require Firebase Authentication ──
    // Add Firebase Auth (e.g. email/password or Google sign-in) to the app,
    // then comment out Option A above and uncomment this block:
    //
    // match /projects/{id} {
    //   allow read, write: if request.auth != null;
    // }
    // match /tasks/{id} {
    //   allow read, write: if request.auth != null;
    // }
    // match /meta/{id} {
    //   allow read, write: if request.auth != null;
    // }
  }
}
